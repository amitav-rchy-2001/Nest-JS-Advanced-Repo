// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider               = "prisma-client"
  output                 = "../src/generated/prisma"
  runtime                = "nodejs"
  moduleFormat           = "cjs"
  generatedFileExtension = "ts"
  importFileExtension    = "js"
}

datasource db {
  provider = "postgresql"
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  userId    String?

  oldValue  Json?
  newValue  Json?
  metadata  Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([action])
  @@index([entity])
  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String?
  title       String
  description String?
  entity      String
  entityId    String?
  metadata    Json?

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String?
  channels  String[]
  metadata  Json?

  isRead    Boolean   @default(false)
  readAt    DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model WebhookDelivery {
  id                 String   @id @default(uuid())
  url                String
  event              String
  payload            Json
  headers            Json?
  status             String   @default("PENDING")
  responseStatusCode Int?
  responseBody       String?
  error              String?
  attempts           Int      @default(0)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deliveredAt        DateTime?

  @@index([event])
  @@index([status])
  @@index([createdAt])
}

model FileProcessingJob {
  id          String   @id @default(uuid())
  fileId      String
  filePath    String
  mimeType    String
  action      String
  status      String   @default("PENDING")
  error       String?
  metadata    Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  processedAt DateTime?

  @@index([fileId])
  @@index([action])
  @@index([status])
}

model Reminder {
  id        String    @id @default(uuid())
  userId    String
  title     String
  message   String
  remindAt  DateTime
  channels  String[]
  status    String    @default("SCHEDULED")
  metadata  Json?
  sentAt    DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([remindAt])
  @@index([status])
}

model SystemAlert {
  id        String    @id @default(uuid())
  title     String
  message   String
  severity  String
  status    String    @default("OPEN")
  metadata  Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  resolvedAt DateTime?

  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

model SearchIndexJob {
  id        String   @id @default(uuid())
  indexName String
  entity    String
  entityId  String
  operation String
  data      Json?
  status    String   @default("PENDING")
  error     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([indexName])
  @@index([entity])
  @@index([entityId])
  @@index([status])
}

model Conversation {
  id        String   @id @default(uuid())
  type      String   @default("DIRECT")
  title     String?
  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  role           String   @default("MEMBER")

  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String?
  attachments    Json?
  metadata       Json?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  readReceipts   MessageReadReceipt[]

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model MessageReadReceipt {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}
model User {
  id                  String    @id @default(uuid())
  email               String?   @unique
  phone               String?   @unique
  passwordHash        String?
  googleId            String?   @unique
  role                UserRole
  fullName            String
  isEmailVerified     Boolean   @default(false)
  isPhoneVerified     Boolean   @default(false)
  isActive            Boolean   @default(true)
  profileComplete     Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  nannyProfile        NannyProfile?
  parentProfile       ParentProfile?
  children            Child[]
  userLanguages       UserLanguage[]
  identityDocuments   IdentityDocument[]
  otpVerifications    OtpVerification[]
  passwordResets      PasswordResetToken[]
  subscriptions       Subscription[]
  payments            Payment[]
  authSessions        AuthSession[]
  signupProgress      SignupProgress?
}

enum UserRole {
  nanny
  parent
}

model NannyProfile {
  id                String       @id @default(uuid())
  userId            String       @unique
  user              User         @relation(fields: [userId], references: [id])
  preferredLanguage LanguageCode?
  faceImageUrl      String?
  accountStatus     NannyStatus  @default(pending_verification)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

enum NannyStatus {
  pending_verification
  verified
  rejected
  suspended
}

model ParentProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  profileImageUrl String?
  addressLine1   String?
  street         String?
  postalCode     String?
  city           String?
  state          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Child {
  id                    String          @id @default(uuid())
  parentId              String
  parent                User            @relation(fields: [parentId], references: [id])
  name                  String
  ageRange              ChildAgeRange
  educationalDays       Weekday[]
  educationalStartTime  String?
  educationalEndTime    String?
  wakeupTime            String?
  napWindowFrom         String?
  napWindowTo           String?
  bedtimeFrom           String?
  bedtimeTo             String?
  restrictions          String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([parentId])
}

enum ChildAgeRange {
  new_infant
  early_infant
  growing_infant
  infant
  young_toddler
  toddler
  early_childhood
  school_age_6_plus
}

enum Weekday {
  monday
  tuesday
  wednesday
  thursday
  friday
}

enum LanguageCode {
  en
  si
  hi
  ar
  fil
}

model UserLanguage {
  id        String       @id @default(uuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  language  LanguageCode
  isPrimary Boolean      @default(false)

  @@unique([userId, language])
}

model IdentityDocument {
  id                 String           @id @default(uuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id])
  documentType       DocumentType
  documentSide       DocumentSide?
  fileUrl            String
  fileKey            String
  mimeType           String?
  fileSizeBytes      Int?
  verificationStatus DocStatus        @default(pending)
  verifiedAt         DateTime?
  createdAt          DateTime         @default(now())
}

enum DocumentType {
  passport
  nid
}
enum DocumentSide {
  front
  back
  single
}
enum DocStatus {
  pending
  approved
  rejected
}

model OtpVerification {
  id        String      @id @default(uuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  phone     String?
  email     String?
  otpCode   String
  otpType   OtpType
  expiresAt DateTime
  isUsed    Boolean     @default(false)
  attempts  Int         @default(0)
  createdAt DateTime    @default(now())
}

enum OtpType {
  phone_verification
  email_verification
  password_reset_phone
  password_reset_email
}

model PasswordResetToken {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  token     String         @unique
  resetVia  ResetVia
  expiresAt DateTime
  isUsed    Boolean        @default(false)
  createdAt DateTime       @default(now())
}

enum ResetVia {
  email
  phone
}

model SubscriptionPlan {
  id           String           @id @default(uuid())
  name         String
  description  String?
  priceAmount  Decimal          @db.Decimal(10, 2)
  currency     String           @default("USD")
  billingCycle BillingCycle
  features     Json?
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  subscriptions Subscription[]
}

enum BillingCycle {
  monthly
  quarterly
  yearly
}

model Subscription {
  id         String             @id @default(uuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id])
  planId     String
  plan       SubscriptionPlan   @relation(fields: [planId], references: [id])
  status     SubscriptionStatus @default(pending)
  startedAt  DateTime?
  expiresAt  DateTime?
  autoRenew  Boolean            @default(true)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  payments   Payment[]
}

enum SubscriptionStatus {
  pending
  active
  expired
  cancelled
  failed
}

model Payment {
  id                   String        @id @default(uuid())
  userId               String
  user                 User          @relation(fields: [userId], references: [id])
  subscriptionId       String?
  subscription         Subscription? @relation(fields: [subscriptionId], references: [id])
  amount               Decimal       @db.Decimal(10, 2)
  currency             String        @default("USD")
  paymentGateway       String?
  gatewayTransactionId String?       @unique
  gatewayPayload       Json?
  status               PaymentStatus @default(pending)
  paidAt               DateTime?
  createdAt            DateTime      @default(now())
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

model AuthSession {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  refreshTokenHash String
  deviceInfo       Json?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())
}

model SignupProgress {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  currentStep    Int      @default(1)
  completedSteps Json     @default("[]")
  metadata       Json?
  updatedAt      DateTime @updatedAt
}
